{
  "run": {
    "phase": "phase3_geo_attention",
    "condition": "real_d",
    "seed": 2027,
    "output_dir": "runs/phase3_geo_attention/phase3_repair_normalized/real_d_alpha_0_2_detached_norm"
  },
  "dataset": {
    "name": "wikitext-2",
    "split": "standard",
    "tokenizer": "gpt2",
    "context_length": 256
  },
  "model": {
    "type": "ergt_v1",
    "vocab_size": null,
    "n_layers": 6,
    "n_heads": 8,
    "hidden_dim": 512,
    "ffn_dim": 2048,
    "dropout": 0.1,
    "bias": true,
    "positional_encoding": "learned_absolute"
  },
  "attention": {
    "type": "geo_attention",
    "distance_mode": "real_d",
    "head_sharing": "shared_d",
    "alpha": {
      "mode": "fixed",
      "initial_value": 0.2,
      "non_negative": true
    },
    "gradient_mode": "detached_d",
    "causal_runtime_distance": true
  },
  "relational_graph": {
    "kernel": "sigmoid_dot_sqrt_d",
    "graph_heads": 1,
    "normalize_hidden": true,
    "diagonal_policy": "keep_for_distance"
  },
  "distance": {
    "formula": "-log(W + epsilon)",
    "epsilon": 0.000001,
    "normalization": "offdiag_zscore_clamp",
    "clip_value": 5.0,
    "diagonal_policy": "zero"
  },
  "training": {
    "optimizer": "adamw",
    "learning_rate": 0.0003,
    "betas": [0.9, 0.95],
    "weight_decay": 0.1,
    "batch_size": 16,
    "max_steps": 1000,
    "warmup_steps": 100,
    "grad_clip": 1.0,
    "eval_interval": 100,
    "checkpoint_interval": 500
  },
  "logging": {
    "train_log": "train_log.jsonl",
    "results": "metrics.json",
    "model_summary": "model_summary.json",
    "log_geometry_diagnostics": true
  }
}
