{
  "run": {
    "phase": "phase1_graph",
    "condition": "graph_observer",
    "seed": 1337,
    "output_dir": "runs/phase1_graph/graph_observer"
  },
  "source_model": {
    "type": "transformer_baseline",
    "checkpoint": "runs/phase0_baseline/proof_wikitext2/checkpoints/best.pt",
    "config": "configs/baseline/proof_wikitext2.json"
  },
  "dataset": {
    "name": "wikitext-2",
    "split": "validation",
    "tokenizer": "gpt2",
    "context_length": 256,
    "max_batches": 32
  },
  "relational_graph": {
    "kernel": "sigmoid_dot_sqrt_d",
    "graph_heads": 1,
    "normalize_hidden": false,
    "diagonal_policy": "report_separately",
    "layers": "all_block_outputs"
  },
  "metrics": {
    "exclude_diagonal": true,
    "sparsity_thresholds": [0.5, 0.75, 0.9, 0.95],
    "controls": ["random_W", "shuffled_W"],
    "save_sample_matrices": true,
    "max_saved_matrices": 16
  },
  "logging": {
    "results": "graph_stats.json",
    "artifacts_dir": "artifacts"
  }
}
