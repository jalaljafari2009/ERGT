{
  "run": {
    "phase": "phase0_baseline",
    "condition": "baseline",
    "seed": 1337,
    "output_dir": "runs/phase0_baseline/pilot_wikitext2"
  },
  "dataset": {
    "name": "wikitext-2",
    "split": "standard",
    "tokenizer": "gpt2",
    "context_length": 256
  },
  "model": {
    "type": "transformer_baseline",
    "vocab_size": null,
    "n_layers": 4,
    "n_heads": 4,
    "hidden_dim": 256,
    "ffn_dim": 1024,
    "dropout": 0.1,
    "bias": true,
    "positional_encoding": "learned_absolute"
  },
  "training": {
    "optimizer": "adamw",
    "learning_rate": 0.0003,
    "betas": [0.9, 0.95],
    "weight_decay": 0.1,
    "batch_size": 8,
    "max_steps": 200,
    "warmup_steps": 20,
    "grad_clip": 1.0,
    "eval_interval": 50,
    "checkpoint_interval": 100
  },
  "logging": {
    "train_log": "train_log.jsonl",
    "results": "baseline_results.json",
    "model_summary": "model_summary.json"
  }
}
