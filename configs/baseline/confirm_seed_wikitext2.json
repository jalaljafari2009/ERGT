{
  "run": {
    "phase": "phase0_baseline",
    "condition": "baseline",
    "seed": 2027,
    "output_dir": "runs/phase0_baseline/confirm_seed_wikitext2"
  },
  "dataset": {
    "name": "wikitext-2",
    "split": "standard",
    "tokenizer": "gpt2",
    "context_length": 256
  },
  "model": {
    "type": "transformer_baseline",
    "vocab_size": null,
    "n_layers": 6,
    "n_heads": 8,
    "hidden_dim": 512,
    "ffn_dim": 2048,
    "dropout": 0.1,
    "bias": true,
    "positional_encoding": "learned_absolute"
  },
  "training": {
    "optimizer": "adamw",
    "learning_rate": 0.0003,
    "betas": [0.9, 0.95],
    "weight_decay": 0.1,
    "batch_size": 16,
    "max_steps": 1000,
    "warmup_steps": 100,
    "grad_clip": 1.0,
    "eval_interval": 100,
    "checkpoint_interval": 500
  },
  "logging": {
    "train_log": "train_log.jsonl",
    "results": "baseline_results.json",
    "model_summary": "model_summary.json"
  }
}
